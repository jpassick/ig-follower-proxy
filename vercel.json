{
  "crons": [
    {
      "path": "/api/cron-anr-batch",
      "schedule": "*/5 12-13 * * *"
    },
    {
      "path": "/api/cron-snapshot-daily",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron-backup-snapshots",
      "schedule": "0 4 * * *"
    }
  ],
  "functions": {
    "api/cron-snapshot-daily.js":   { "maxDuration": 300 },
    "api/cron-anr-batch.js":        { "maxDuration": 300 },
    "api/cron-backup-snapshots.js": { "maxDuration": 30 },
    "api/followers.js":             { "maxDuration": 30 }
  }
}
